{
  "info": {
    "name": "AirbCar Deep Tests",
    "description": "In-depth API tests: validates business logic, permissions, data integrity, and edge cases.\n\nRun AFTER your backend is running on localhost:8000.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('access_token');",
          "if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Phase 1 — Auth Flow",
      "item": [
        {
          "name": "1.1 Access protected endpoint WITHOUT token → must get 401",
          "event": [
            { "listen": "prerequest", "script": { "exec": ["pm.request.headers.remove('Authorization');"] } },
            { "listen": "test", "script": { "exec": [
              "pm.test('Unauthenticated request returns 401', () => {",
              "    pm.response.to.have.status(401);",
              "});",
              "pm.test('Response has error message', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.any.keys('error', 'detail');",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users/me/" }
        },
        {
          "name": "1.2 Access with FAKE token → must get 401",
          "event": [
            { "listen": "prerequest", "script": { "exec": [
              "pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer fake.invalid.token123' });"
            ]}},
            { "listen": "test", "script": { "exec": [
              "pm.test('Fake token returns 401', () => pm.response.to.have.status(401));"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users/me/" }
        },
        {
          "name": "1.3 Login with WRONG password → must get 401",
          "event": [
            { "listen": "prerequest", "script": { "exec": ["pm.request.headers.remove('Authorization');"] } },
            { "listen": "test", "script": { "exec": [
              "pm.test('Wrong password returns 401', () => pm.response.to.have.status(401));",
              "pm.test('Error message says invalid', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.error.toLowerCase()).to.include('invalid');",
              "});"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"COMPLETELY_WRONG_PASSWORD_999\"\n}" }
          }
        },
        {
          "name": "1.4 Login with CORRECT credentials → validate response shape",
          "event": [
            { "listen": "prerequest", "script": { "exec": ["pm.request.headers.remove('Authorization');"] } },
            { "listen": "test", "script": { "exec": [
              "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Has access token (string)', () => {",
              "    pm.expect(json.access).to.be.a('string');",
              "    pm.expect(json.access.length).to.be.above(20);",
              "});",
              "pm.test('Has refresh token (string)', () => {",
              "    pm.expect(json.refresh).to.be.a('string');",
              "    pm.expect(json.refresh.length).to.be.above(20);",
              "});",
              "pm.test('User object has required fields', () => {",
              "    pm.expect(json.user).to.have.property('id');",
              "    pm.expect(json.user).to.have.property('email');",
              "    pm.expect(json.user).to.have.property('role');",
              "});",
              "pm.test('Password is NOT in response', () => {",
              "    pm.expect(json.user).to.not.have.property('password');",
              "    pm.expect(JSON.stringify(json)).to.not.include('password');",
              "});",
              "pm.environment.set('access_token', json.access);",
              "pm.environment.set('refresh_token', json.refresh);",
              "pm.environment.set('user_id', json.user.id);",
              "pm.environment.set('user_role', json.user.role);"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}" }
          }
        },
        {
          "name": "1.5 Verify token → confirms auth works end-to-end",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Verify returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Token is valid', () => pm.expect(json.valid).to.eql(true));",
              "pm.test('User email matches login', () => {",
              "    pm.expect(json.user.email).to.eql(pm.environment.get('user_email'));",
              "});"
            ]}}
          ],
          "request": { "method": "POST", "url": "{{base_url}}/api/verify-token/" }
        }
      ]
    },
    {
      "name": "Phase 2 — Listings (read + permission)",
      "item": [
        {
          "name": "2.1 List listings → validate data structure",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Has data array', () => pm.expect(json.data).to.be.an('array'));",
              "pm.test('Has count (number)', () => pm.expect(json.count).to.be.a('number'));",
              "if (json.data.length > 0) {",
              "    const listing = json.data[0];",
              "    pm.test('Listing has required fields', () => {",
              "        pm.expect(listing).to.have.property('id');",
              "        pm.expect(listing).to.have.property('brand');",
              "        pm.expect(listing).to.have.property('dailyRate');",
              "        pm.expect(listing).to.have.property('location');",
              "    });",
              "    pm.test('Price is a positive number', () => {",
              "        const price = parseFloat(listing.dailyRate || listing.price);",
              "        pm.expect(price).to.be.above(0);",
              "    });",
              "    pm.environment.set('listing_id', listing.id);",
              "    pm.environment.set('listing_price', listing.dailyRate || listing.price);",
              "    pm.environment.set('listing_location', listing.location);",
              "}"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/listings/?page_size=5" }
        },
        {
          "name": "2.2 Get single listing → has full detail fields",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const d = json.data;",
              "pm.test('Has vehicle details', () => {",
              "    pm.expect(d).to.have.property('brand');",
              "    pm.expect(d).to.have.property('model_name');",
              "    pm.expect(d).to.have.property('year');",
              "    pm.expect(d).to.have.property('transmission');",
              "    pm.expect(d).to.have.property('fuelType');",
              "});",
              "pm.test('Has pricing', () => {",
              "    pm.expect(d).to.have.any.keys('dailyRate', 'price_per_day');",
              "});",
              "pm.test('Has images array', () => {",
              "    pm.expect(d.images).to.be.an('array');",
              "});",
              "pm.test('Year is reasonable (1990-2030)', () => {",
              "    pm.expect(d.year).to.be.within(1990, 2030);",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/listings/{{listing_id}}/" }
        },
        {
          "name": "2.3 Customer tries to CREATE listing → must get 403",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Customer cannot create listing (403)', () => {",
              "    pm.expect([401, 403]).to.include(pm.response.code);",
              "});"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/listings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"make\": \"Hack\",\n  \"model\": \"Attempt\",\n  \"year\": 2023,\n  \"price_per_day\": 1000,\n  \"location\": \"Test\"\n}" }
          }
        },
        {
          "name": "2.4 Customer tries to DELETE listing → must be blocked",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Customer cannot delete listing', () => {",
              "    pm.expect([401, 403, 404]).to.include(pm.response.code);",
              "});"
            ]}}
          ],
          "request": { "method": "DELETE", "url": "{{base_url}}/listings/{{listing_id}}/" }
        },
        {
          "name": "2.5 Filter listings by price range → results within range",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.data && json.data.length > 0) {",
              "    pm.test('All prices within range', () => {",
              "        json.data.forEach(listing => {",
              "            const price = parseFloat(listing.dailyRate || listing.price || 0);",
              "            if (price > 0) {",
              "                pm.expect(price).to.be.at.least(1000);",
              "                pm.expect(price).to.be.at.most(10000);",
              "            }",
              "        });",
              "    });",
              "}"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/listings/?min_price=1000&max_price=10000" }
        }
      ]
    },
    {
      "name": "Phase 3 — Booking Business Logic",
      "item": [
        {
          "name": "3.1 Create booking → verify price calculation",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const s = pm.response.code;",
              "pm.test('Create returns 201 or 400 (date conflict)', () => pm.expect([201,400]).to.include(s));",
              "if (s === 201) {",
              "    const json = pm.response.json();",
              "    const b = json.data;",
              "    pm.test('Booking has id', () => pm.expect(b.id).to.be.a('number'));",
              "    pm.test('Status is pending or confirmed', () => {",
              "        pm.expect(['pending','confirmed']).to.include(b.status);",
              "    });",
              "    // Verify price calculation: 5 days × price + 5000 deposit + 25 fee",
              "    const listingPrice = parseFloat(pm.environment.get('listing_price'));",
              "    if (listingPrice > 0) {",
              "        const expectedTotal = (listingPrice * 5) + 5000 + 25;",
              "        const actualTotal = parseFloat(b.price || b.total_amount);",
              "        pm.test('Total = (5 days × price) + 5000 deposit + 25 fee = ' + expectedTotal, () => {",
              "            pm.expect(actualTotal).to.be.closeTo(expectedTotal, 1);",
              "        });",
              "    }",
              "    pm.environment.set('booking_id', b.id);",
              "    pm.environment.set('booking_pickup', '2026-06-10');",
              "    pm.environment.set('booking_return', '2026-06-15');",
              "}"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": {{listing_id}},\n  \"pickup_date\": \"2026-06-10\",\n  \"return_date\": \"2026-06-15\",\n  \"pickup_time\": \"09:00\",\n  \"return_time\": \"18:00\",\n  \"payment_method\": \"cash\"\n}" }
          }
        },
        {
          "name": "3.2 OVERLAPPING dates on same listing → must reject",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Overlapping booking returns 400', () => pm.response.to.have.status(400));",
              "const json = pm.response.json();",
              "pm.test('Error mentions dates/availability', () => {",
              "    const msg = (json.error || '').toLowerCase();",
              "    pm.expect(msg).to.match(/available|date|conflict/);",
              "});"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": {{listing_id}},\n  \"pickup_date\": \"2026-06-12\",\n  \"return_date\": \"2026-06-18\",\n  \"pickup_time\": \"09:00\",\n  \"return_time\": \"18:00\",\n  \"payment_method\": \"cash\"\n}" }
          }
        },
        {
          "name": "3.3 Return date BEFORE pickup → must reject",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Invalid dates return 400', () => pm.response.to.have.status(400));",
              "const json = pm.response.json();",
              "pm.test('Error mentions date order', () => {",
              "    const msg = (json.error || '').toLowerCase();",
              "    pm.expect(msg).to.match(/return|after|before|date/);",
              "});"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": {{listing_id}},\n  \"pickup_date\": \"2026-07-20\",\n  \"return_date\": \"2026-07-15\",\n  \"payment_method\": \"cash\"\n}" }
          }
        },
        {
          "name": "3.4 Invalid listing ID → must reject",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Non-existent listing returns 400 or 404', () => {",
              "    pm.expect([400, 404]).to.include(pm.response.code);",
              "});"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": 999999,\n  \"pickup_date\": \"2026-08-01\",\n  \"return_date\": \"2026-08-05\",\n  \"payment_method\": \"cash\"\n}" }
          }
        },
        {
          "name": "3.5 Invalid payment method → must reject",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Invalid payment method returns 400', () => pm.response.to.have.status(400));",
              "const json = pm.response.json();",
              "pm.test('Error mentions payment', () => {",
              "    const msg = (json.error || '').toLowerCase();",
              "    pm.expect(msg).to.include('payment');",
              "});"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/bookings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": {{listing_id}},\n  \"pickup_date\": \"2026-09-01\",\n  \"return_date\": \"2026-09-05\",\n  \"payment_method\": \"bitcoin\"\n}" }
          }
        },
        {
          "name": "3.6 Read back booking → verify data matches what we sent",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const status = pm.response.code;",
              "if (status === 200) {",
              "    const json = pm.response.json();",
              "    const b = json.data;",
              "    pm.test('Booking is for correct listing', () => {",
              "        // listing can be an ID, a string, or a nested object",
              "        let lid = b.listing_id || b.listing;",
              "        if (typeof lid === 'object' && lid !== null) lid = lid.id;",
              "        if (b.listing_details) lid = b.listing_details.id;",
              "        pm.expect(String(lid)).to.eql(String(pm.environment.get('listing_id')));",
              "    });",
              "    pm.test('Payment method is cash', () => {",
              "        pm.expect(b.payment_method).to.eql('cash');",
              "    });",
              "} else {",
              "    pm.test('Booking detail returns 200 (skipped - no booking_id)', () => {",
              "        pm.expect([200,404]).to.include(status);",
              "    });",
              "}"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/bookings/{{booking_id}}/" }
        },
        {
          "name": "3.7 Cancel booking → status changes",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const status = pm.response.code;",
              "pm.test('Cancel returns 200', () => pm.expect([200,400,404]).to.include(status));",
              "if (status === 200) {",
              "    const json = pm.response.json();",
              "    pm.test('Status is now cancelled', () => {",
              "        const s = (json.data && json.data.status) || json.status;",
              "        pm.expect(s).to.eql('cancelled');",
              "    });",
              "}"
            ]}}
          ],
          "request": { "method": "POST", "url": "{{base_url}}/bookings/{{booking_id}}/cancel/" }
        }
      ]
    },
    {
      "name": "Phase 4 — User Profile & Data",
      "item": [
        {
          "name": "4.1 Get profile → verify it matches login user",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Email matches logged in user', () => {",
              "    pm.expect(json.data.email).to.eql(pm.environment.get('user_email'));",
              "});",
              "pm.test('ID matches', () => {",
              "    pm.expect(String(json.data.id)).to.eql(String(pm.environment.get('user_id')));",
              "});",
              "pm.test('No password in response', () => {",
              "    pm.expect(JSON.stringify(json)).to.not.match(/password/i);",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users/me/" }
        },
        {
          "name": "4.2 Update profile → change sticks",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('First name updated', () => {",
              "    pm.expect(json.data.first_name).to.eql('DeepTest');",
              "});",
              "pm.test('Last name updated', () => {",
              "    pm.expect(json.data.last_name).to.eql('Runner');",
              "});"
            ]}}
          ],
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/me/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"first_name\": \"DeepTest\",\n  \"last_name\": \"Runner\"\n}" }
          }
        },
        {
          "name": "4.3 Read profile again → confirms update persisted",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Name persisted correctly', () => {",
              "    pm.expect(json.data.first_name).to.eql('DeepTest');",
              "    pm.expect(json.data.last_name).to.eql('Runner');",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users/me/" }
        },
        {
          "name": "4.4 Stats → has correct structure",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Has bookings breakdown', () => {",
              "    pm.expect(json.bookings).to.be.an('object');",
              "});",
              "pm.test('Booking counts are numbers', () => {",
              "    pm.expect(json.bookings.total).to.be.a('number');",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users/me/stats/" }
        }
      ]
    },
    {
      "name": "Phase 5 — Favorites Lifecycle",
      "item": [
        {
          "name": "5.1 Add favorite",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Add returns 201 or 200', () => pm.expect([200,201]).to.include(pm.response.code));",
              "const json = pm.response.json();",
              "if (json.data && json.data.id) pm.environment.set('favorite_id', json.data.id);"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/favorites/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": {{listing_id}}\n}" }
          }
        },
        {
          "name": "5.2 List favorites → listing is there",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "const favs = json.data || json.favorites || json.results || [];",
              "pm.test('Favorites is not empty', () => {",
              "    pm.expect(favs.length).to.be.above(0);",
              "});",
              "pm.test('Our listing is in favorites', () => {",
              "    const lid = parseInt(pm.environment.get('listing_id'));",
              "    const found = favs.some(f => {",
              "        // listing can be nested object with .id or a direct ID",
              "        if (f.listing && typeof f.listing === 'object') return f.listing.id === lid;",
              "        return (f.listing_id || f.listing) === lid;",
              "    });",
              "    pm.expect(found).to.eql(true);",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/favorites/my-favorites/" }
        },
        {
          "name": "5.3 Remove favorite",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Delete returns 200', () => pm.expect([200,204]).to.include(pm.response.code));"
            ]}}
          ],
          "request": { "method": "DELETE", "url": "{{base_url}}/favorites/by-listing/{{listing_id}}/" }
        },
        {
          "name": "5.4 List favorites again → listing is gone",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Our listing is no longer in favorites', () => {",
              "    const lid = parseInt(pm.environment.get('listing_id'));",
              "    const found = (json.data || []).some(f => (f.listing_id || f.listing) === lid || (f.listing_details && f.listing_details.id === lid));",
              "    pm.expect(found).to.eql(false);",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/favorites/my-favorites/" }
        }
      ]
    },
    {
      "name": "Phase 6 — Reviews",
      "item": [
        {
          "name": "6.1 Create review → validate response",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const s = pm.response.code;",
              "pm.test('Create returns 200 or 201', () => pm.expect([200,201]).to.include(s));",
              "const json = pm.response.json();",
              "if (json.data) {",
              "    pm.test('Rating is 5', () => pm.expect(json.data.rating).to.eql(5));",
              "    pm.test('Comment matches', () => {",
              "        pm.expect(json.data.comment).to.include('deep test');",
              "    });",
              "    pm.environment.set('review_id', json.data.id);",
              "}"
            ]}}
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/reviews/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"listing_id\": {{listing_id}},\n  \"rating\": 5,\n  \"comment\": \"Excellent vehicle - deep test review\"\n}" }
          }
        },
        {
          "name": "6.2 List reviews for listing → our review appears",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "if (json.data && json.data.length > 0) {",
              "    pm.test('Reviews contain our comment', () => {",
              "        const found = json.data.some(r => r.comment && r.comment.includes('deep test'));",
              "        pm.expect(found).to.eql(true);",
              "    });",
              "}"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/reviews/?listing_id={{listing_id}}" }
        }
      ]
    },
    {
      "name": "Phase 7 — Notifications",
      "item": [
        {
          "name": "7.1 List notifications → validate structure",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "// NotificationListView uses ListAPIView — returns results[] or array at top level",
              "const notifs = json.results || json.data || (Array.isArray(json) ? json : []);",
              "pm.test('Response is array or has results', () => pm.expect(notifs).to.be.an('array'));",
              "if (notifs.length > 0) {",
              "    pm.test('Notification has required fields', () => {",
              "        const n = notifs[0];",
              "        pm.expect(n).to.have.property('id');",
              "        pm.expect(n).to.have.property('message');",
              "    });",
              "    pm.environment.set('notification_id', notifs[0].id);",
              "}"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/notifications/" }
        },
        {
          "name": "7.2 Mark all read",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('Returns 200', () => pm.response.to.have.status(200));"
            ]}}
          ],
          "request": { "method": "POST", "url": "{{base_url}}/notifications/read-all/" }
        }
      ]
    },
    {
      "name": "Phase 8 — Admin Security Check",
      "item": [
        {
          "name": "8.1 Customer accesses admin stats → should NOT work",
          "event": [
            { "listen": "test", "script": { "exec": [
              "const s = pm.response.code;",
              "// If this returns 200, your admin endpoints are NOT protected!",
              "if (s === 200) {",
              "    pm.test('⚠️ WARNING: Admin endpoint is UNPROTECTED — returns 200 to customer!', () => {",
              "        pm.expect(s).to.eql(403, 'Admin stats should require admin role');",
              "    });",
              "} else {",
              "    pm.test('Admin stats correctly blocked for customer (403)', () => {",
              "        pm.expect([401,403]).to.include(s);",
              "    });",
              "}"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/api/admin/stats/" }
        },
        {
          "name": "8.2 Customer accesses user list → should NOT work",
          "event": [
            { "listen": "test", "script": { "exec": [
              "pm.test('User list blocked for non-admin', () => {",
              "    pm.expect([401,403]).to.include(pm.response.code);",
              "});"
            ]}}
          ],
          "request": { "method": "GET", "url": "{{base_url}}/users/" }
        }
      ]
    }
  ]
}
