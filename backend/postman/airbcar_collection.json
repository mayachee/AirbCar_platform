{
  "info": {
    "name": "AirbCar Backend API",
    "description": "Complete API test collection for the AirbCar car rental platform.\n\nRun order: 01 Health → 02 Auth → 03 Listings → 04 Bookings → 05 Users → 06 Partners → 07 Reviews → 08 Favorites → 09 Notifications → 10 Newsletter → 11 Admin",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const token = pm.environment.get('access_token');",
          "if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 — Health & Root",
      "item": [
        {
          "name": "Root endpoint",
          "request": { "method": "GET", "url": "{{base_url}}/" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Root returns 200', () => pm.response.to.have.status(200));"
          ]}}]
        },
        {
          "name": "Health check",
          "request": { "method": "GET", "url": "{{base_url}}/api/health/" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Health returns 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has status field', () => pm.expect(json).to.have.property('status'));"
          ]}}]
        }
      ]
    },
    {
      "name": "02 — Authentication",
      "item": [
        {
          "name": "Register (customer)",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "// Clear any existing token so register runs unauthenticated",
                "pm.request.headers.remove('Authorization');"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "const status = pm.response.code;",
                "pm.test('Register returns 201 or 400 (exists)', () => pm.expect([201,400]).to.include(status));",
                "if (status === 201) {",
                "    const json = pm.response.json();",
                "    // Backend returns { access, refresh, user } at top level",
                "    if (json.access) pm.environment.set('access_token', json.access);",
                "    if (json.refresh) pm.environment.set('refresh_token', json.refresh);",
                "    if (json.user && json.user.id) pm.environment.set('user_id', json.user.id);",
                "    console.log('Registered — token saved');",
                "}"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/register/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser_{{$timestamp}}\",\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\"\n}" }
          }
        },
        {
          "name": "Login (customer)",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "pm.request.headers.remove('Authorization');"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "// Backend returns { access, refresh, user } at top level",
                "pm.test('Has access token', () => pm.expect(json).to.have.property('access'));",
                "pm.test('Has refresh token', () => pm.expect(json).to.have.property('refresh'));",
                "pm.test('Has user object', () => pm.expect(json).to.have.property('user'));",
                "if (json.access) pm.environment.set('access_token', json.access);",
                "if (json.refresh) pm.environment.set('refresh_token', json.refresh);",
                "if (json.user && json.user.id) pm.environment.set('user_id', json.user.id);",
                "console.log('Login OK — token: ' + (json.access || '').substring(0, 20) + '...');"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/login/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}" }
          }
        },
        {
          "name": "Refresh token",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [
                "pm.request.headers.remove('Authorization');"
              ]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Refresh returns 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "if (json.access) pm.environment.set('access_token', json.access);",
                "if (json.refresh) pm.environment.set('refresh_token', json.refresh);"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/token/refresh/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}" }
          }
        },
        {
          "name": "Verify token",
          "request": { "method": "POST", "url": "{{base_url}}/api/verify-token/" },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Verify token returns 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Token is valid', () => pm.expect(json).to.have.property('valid'));",
            "pm.test('Has user data', () => pm.expect(json).to.have.property('user'));"
          ]}}]
        },
        {
          "name": "Resend verification email",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": ["pm.request.headers.remove('Authorization');"]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('Returns 200', () => pm.response.to.have.status(200));"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/resend-verification/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{user_email}}\"\n}" }
          }
        },
        {
          "name": "Password reset request",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": ["pm.request.headers.remove('Authorization');"]}
            },
            {
              "listen": "test",
              "script": { "exec": [
                "const status = pm.response.code;",
                "pm.test('Returns 200 or 500 (email config)', () => pm.expect([200,500]).to.include(status));"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/password-reset/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{user_email}}\"\n}" }
          }
        }
      ]
    },
    {
