          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Returns 200', () => pm.response.to.have.status(200));",
            "const json = pm.response.json();",
            "pm.test('Has data', () => pm.expect(json).to.have.property('data'));",
            "pm.test('Has id', () => pm.expect(json.data).to.have.property('id'));"
          ]}}]
        },
        {
          "name": "Create listing (auth, partner only)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/listings/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"make\": \"Toyota\",\n  \"model\": \"Corolla\",\n  \"year\": 2023,\n  \"color\": \"White\",\n  \"transmission\": \"automatic\",\n  \"fuel_type\": \"diesel\",\n  \"seating_capacity\": 5,\n  \"vehicle_style\": \"sedan\",\n  \"price_per_day\": 3500,\n  \"location\": \"Algiers\",\n  \"vehicle_description\": \"Test vehicle from Newman\",\n  \"available_features\": [\"AC\", \"GPS\"],\n  \"is_available\": true\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const status = pm.response.code;",
            "// 201=created, 401=not logged in, 403=not a partner",
            "pm.test('Create returns 201/401/403', () => pm.expect([201,401,403]).to.include(status));",
            "if (status === 201) {",
            "    const json = pm.response.json();",
            "    if (json.data && json.data.id) pm.environment.set('listing_id', json.data.id);",
            "}"
          ]}}]
        },
        {
          "name": "Update listing (PATCH)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/listings/{{listing_id}}/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"price_per_day\": 4000,\n  \"is_available\": true\n}" }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const status = pm.response.code;",
            "pm.test('Update returns 200/401/403', () => pm.expect([200,401,403]).to.include(status));"
          ]}}]
        }
      ]
    },
