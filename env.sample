# Copy this file to `.env` and fill values (NEVER commit `.env`)
#
# Backend (Django)
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

DATABASE_HOST=aws-1-eu-north-1.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres.xxxxx
DATABASE_PASSWORD=change-me

EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Optional bootstrap superuser (leave blank if not needed)
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Frontend (Next.js)
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional convenience (if your code uses it)
DATABASE_URL=




