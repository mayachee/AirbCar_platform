# ====================================================================
# .env.local.example - VISITOR/LOCAL DEVELOPMENT SETUP
# --------------------------------------------------------------------
# INSTRUCTIONS: Copy this file to .env.local before running:
# cp .env.local.example .env.local
# 
# This configuration uses LOCAL database with sample data.
# Perfect for visitors, testing, and local development.
# ====================================================================

# Django Configuration
SECRET_KEY=auto-generated-by-make-local
DEBUG=False

# 1. LOCAL DATABASE CONFIG (Uses local PostgreSQL container)
DATABASE_HOST=db
DATABASE_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local_dev_password

# 2. DJANGO SUPERUSER CREATION
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin123

# 3. FRONTEND VARIABLES
NEXT_PUBLIC_DJANGO_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000

# 4. INITIALIZATION (Loads sample data on first run)
FIRST_RUN=1
LOAD_INITIAL_FIXTURE=1